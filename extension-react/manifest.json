{
    "manifest_version": 3,
    "name": "PhishBlocker",
    "version": "2.0.0",
    "description": "Advanced AI-driven phishing detection and protection",
    "permissions": [
        "activeTab",
        "storage",
        "webRequest",
        "webNavigation",
        "declarativeNetRequest",
        "declarativeNetRequestFeedback",
        "sidePanel",
        "contextMenus",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>",
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://www.google.com/*",
        "https://www.bing.com/*",
        "https://duckduckgo.com/*"
    ],
    "background": {
        "service_worker": "src/background/background.js",
        "type": "module"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "side_panel": {
        "default_path": "src/sidepanel/sidepanel.html"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content/content.js"
            ]
        },
        {
            "matches": [
                "*://web.whatsapp.com/*"
            ],
            "js": [
                "src/content/whatsapp.js"
            ],
            "all_frames": true
        },
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "src/content/forensics.js"
            ]
        },
        {
            "matches": [
                "https://www.google.com/search*",
                "https://www.bing.com/search*",
                "https://duckduckgo.com/*"
            ],
            "js": [
                "src/content/searchHUD.js"
            ]
        },
        {
            "matches": [
                "https://mail.google.com/*",
                "https://outlook.live.com/*",
                "https://outlook.office.com/*",
                "https://outlook.office365.com/*"
            ],
            "js": [
                "src/content/webmail.js"
            ]
        },
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "src/content/quishing.js"
            ]
        },
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "src/content/cosmetic_filter.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "src/warning/warning.html",
                "assets/*",
                "rules/*",
                "*.wasm"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "tracker_rules",
                "enabled": true,
                "path": "rules/tracker_rules.json"
            }
        ]
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    }
}