    {
        "id": 8,
        "priority": 1,
        "action": {
            "type": "redirect",
            "redirect": {
                "transform": {
                    "removeParams": [
                        "utm_source",
                        "utm_medium",
                        "utm_campaign",
                        "utm_term",
                        "utm_content",
                        "fbclid",
                        "gclid",
                        "msclkid",
                        "mc_eid"
                    ]
                }
            }
        },
        "condition": {
            "urlFilter": "*",
            "resourceTypes": [
                "main_frame"
            ],
            "excludedDomains": [
                "accounts.google.com",
                "login.microsoftonline.com",
                "appleid.apple.com",
                "paypal.com",
                "stripe.com",
                "bankofamerica.com",
                "chase.com"
            ]
        }
